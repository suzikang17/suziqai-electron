{
  "name": "suziqai",
  "version": "0.1.0",
  "description": "AI-assisted browser test authoring with Playwright",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently \"vite\" \"tsc -p tsconfig.main.json --watch\" \"NODE_ENV=development electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.84",
    "electron": "^41.0.4",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
